# epay-go/.env.example
# 数据库配置
DB_USER=epay
DB_PASSWORD=epay123
DB_NAME=epay
DB_PORT=5432

# Go 模块代理
GOPROXY=https://goproxy.cn,direct

# npm 镜像（阿里云镜像，解决前端构建时 npm 安装慢/不稳定的问题）
NPM_REGISTRY=https://registry.npmmirror.com

# JWT 密钥
JWT_SECRET=your-super-secret-key-change-in-production

# 默认管理员初始化（仅数据库中不存在管理员时生效）
DEFAULT_ADMIN_USERNAME=epay_admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付配置
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

#域名配置
SITE_ADDRESS=pay.example.com
ACME_EMAIL=admin@example.com
REDIS_PASSWORD=change-me-in-production